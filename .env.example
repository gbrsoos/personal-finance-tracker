# ─────────────────────────────────────────────
# Enable Banking (PSD2 API)
# Sign up at https://enablebanking.com
# Create a Restricted (personal) application
# ─────────────────────────────────────────────
ENABLE_BANKING_APP_ID=your-application-id-here

# Path to the RSA private key generated with:
# openssl genrsa -out secrets/private.pem 2048
ENABLE_BANKING_KEY_PATH=./secrets/private.pem

# OAuth callback URL — must match what you registered in Enable Banking portal
# Generate local SSL cert with: mkcert localhost 127.0.0.1
REDIRECT_URL=https://localhost:8000/callback

# Paths to mkcert SSL certificate and key
# Generate with: mkcert localhost 127.0.0.1
# Files will be named localhost+1.pem and localhost+1-key.pem
SSL_CERT_PATH=./secrets/localhost+1.pem
SSL_KEY_PATH=./secrets/localhost+1-key.pem

# Path to the sessions file where bank session tokens are stored
SESSIONS_INFO_PATH=./secrets/sessions.json

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
# SQLite (local development)
DATABASE_URL=sqlite:///./data/finance.db

# PostgreSQL (production — uncomment and fill in when deploying)
# DATABASE_URL=postgresql://user:password@localhost:5432/finance

# ─────────────────────────────────────────────
# AI APIs
# ─────────────────────────────────────────────
# Anthropic API key — used for transaction categorization
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API key — used for transaction embeddings (text-embedding-3-small)
# Get yours at https://platform.openai.com
OPENAI_API_KEY=sk-your-key-here

# ─────────────────────────────────────────────
# App configuration
# ─────────────────────────────────────────────
# Currencies to track — JSON array format
CURRENCIES=["HUF","EUR","USD"]

# In case the webapp is being run from a remote server
# Required for a watcher systemctl script that pings the repo every 10 minutes 
# and automatically deploys when there is a new version released
DEPLOY_CWD="/home/user/personal-finance-tracker"
